# claude-notify — Configuration
# Non-secret config values live here. Secrets are in OS keyring.
#
# Setup:
#   1. Copy this file to .env and fill in config values below
#   2. Run: python scripts/migrate_secrets.py --set SMTP_PASS "your-app-password"
#   3. Repeat --set for each secret (see bottom of file)
#
# Verify:
#   python scripts/migrate_secrets.py --verify

# SMTP (for email delivery)
SMTP_USER=your-email@gmail.com
SMTP_TO=recipient@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ntfy.sh (for push notifications)
NTFY_SERVER=https://ntfy.sh

# ---------------------------------------------------------------
# Secrets (stored in OS keyring, NOT in this file)
# ---------------------------------------------------------------
# SMTP_PASS           - SMTP password or app password
# NTFY_TOPIC          - ntfy.sh topic name
# DISCORD_WEBHOOK     - Discord webhook URL
# DISCORD_TOKEN       - Discord bot token (optional)
# GOOGLE_MAPS_API_KEY - Google Maps API key (optional)
